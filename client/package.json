
{
  "name": "campblast-client",
  "private": true,
  "version": "1.0.0",
  "description": "CampBlast - WhatsApp Bulk Messaging Application",
  "author": "OSDuo Tech",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:all": "npm run build && node scripts/copy-server.js",
    "preview": "vite preview",
    "electron:dev": "npm run build:all && electron .",
    "electron:build": "npm run build:all && electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-log": "^5.1.7",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.campblast.app",
    "productName": "CampBlast",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server/",
        "to": "server/",
        "filter": ["**/*", "!node_modules", "!package-lock.json"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "CampBlast.exe"
    },
    "asar": true,
    "asarUnpack": [
      "server/**/*"
    ]
  }
}
