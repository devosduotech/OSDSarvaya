{
  "name": "osdsarvaya-client",
  "private": true,
  "version": "1.1.13",
  "description": "OSDSarvaya - WhatsApp Bulk Messaging Application",
  "author": "OSDuo Tech",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:all": "npm run build && node scripts/copy-server.js",
    "preview": "vite preview",
    "electron:dev": "npm run build:all && electron .",
    "electron:build": "npm run build:all && electron-builder --win --publish never"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-log": "^5.1.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.7.5",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^20.12.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.osdsarvaya.app",
    "productName": "OSDSarvaya",
    "copyright": "Copyright (c) 2024 OSDuo Tech",
    "nodeVersion": "22.22.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../production.env",
        "to": "production.env"
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "publisherName": "OSDuo Tech"
    },
    "nsis": {
      "artifactName": "OSDSarvayaSetup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OSDSarvaya",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "dist/**/*",
      "server/**/*",
      "server/node_modules/**/*"
    ]
  }
}
