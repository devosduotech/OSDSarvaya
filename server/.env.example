
# The environment for the application ('development' or 'production')
NODE_ENV=development

# The port the server will listen on
PORT=3001

# The allowed origin for CORS requests (your frontend URL)
# In development with Vite, this is typically 'http://localhost:5173'
# In production, this should be the public URL where your app is hosted
CORS_ORIGIN=http://localhost:5173

# A long, random, and secret string used for signing authentication tokens
JWT_SECRET=your_super_secret_and_long_random_string_12345

# The credentials for the application's admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
